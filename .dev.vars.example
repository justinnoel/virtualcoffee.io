# Local dev env vars for vinext / wrangler.
# Copy to `.dev.vars` and fill in values.
# Loaded automatically by wrangler/miniflare in `vinext dev`.
# `.dev.vars` is gitignored via the `.env*.local`/`.dev.vars*` patterns.

# Site identity — also defined in wrangler.jsonc vars; override for local.
SITE_URL="http://localhost:3001"
ENVIRONMENT="development"

# Craft CMS (events). Leaving blank makes events.ts fall back to mock data.
CMS_URL=""
CMS_TOKEN=""

# GitHub PAT used for the sponsors + members GraphQL queries.
# Empty -> sponsors uses mocks (non-production), members uses mocks always.
GITHUB_TOKEN=""

# Airtable key.
# PUBLIC_AIRTABLE_API_KEY: monthly-challenge dashboards (still on Airtable;
# removed in a follow-up). The 4 public forms are now on D1 + send_email.
PUBLIC_AIRTABLE_API_KEY=""

# Per-form notification recipient lists (comma-separated). Used by
# src/util/forms/action.ts to notify the team after a D1 insert. Every
# recipient must be a verified address in the Cloudflare Email Routing
# dashboard, or the send silently drops for that address.
# `wrangler dev` lacks the send_email binding entirely — the action falls back
# to a console.log of the would-be notification, so leaving these blank in
# .dev.vars is fine for local work.
LUNCH_AND_LEARN_NOTIFY_LIST=""
COC_NOTIFY_LIST=""
COFFEE_TABLE_NOTIFY_LIST=""
VOLUNTEER_NOTIFY_LIST=""

# Shared secret required by /_cache (on-demand revalidation).
# Send as `Authorization: Bearer <secret>` or `?secret=<secret>`.
# Must be set as a Cloudflare secret in prod (`wrangler secret put REVALIDATE_SECRET`).
# Without it, /_cache returns 401 to anything.
REVALIDATE_SECRET=""

# Join-link targets — destinations for the /join-slack and /join-coffee
# route handlers. Treated as secrets (don't commit; `wrangler secret put` in prod).
# Without any of these set, the corresponding route returns 401.
SLACK_JOIN_LINK=""
ZOOM_TUESDAYS=""
ZOOM_THURSDAYS=""
